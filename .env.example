# ============================================================================
# Variables de Entorno - Sistema Financiero Distribuido
# ============================================================================
# Copia este archivo a .env y personaliza los valores según necesites
#
# NOTA: Nunca commits .env a git, solo .env.example
# ============================================================================

# ============================================================================
# PostgreSQL - Configuración de Base de Datos
# ============================================================================
# Docker PostgreSQL (Puerto 5433)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ms_main
POSTGRES_PORT=5433

# PostgreSQL Existente (Puerto 5432)
EXISTING_DB_HOST=localhost
EXISTING_DB_PORT=5432
EXISTING_DB_USER=postgres
EXISTING_DB_PASSWORD=postgres

# Bases de datos
MS_CLIENTES_DB_NAME=db_clientes
MS_CUENTAS_DB_NAME=db_cuentas

# ============================================================================
# RabbitMQ - Configuración de Message Broker
# ============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================================================
# Spring Boot - Configuración de Microservicios
# ============================================================================

# ms-clientes
MS_CLIENTES_PORT=8001
MS_CLIENTES_ACTIVE_PROFILE=dev

# ms-cuentas
MS_CUENTAS_PORT=8002
MS_CUENTAS_ACTIVE_PROFILE=dev

# ============================================================================
# Logging y Debugging
# ============================================================================
LOG_LEVEL=INFO
SPRING_JPA_SHOW_SQL=false

# ============================================================================
# NOTA DE SEGURIDAD
# ============================================================================
# En DESARROLLO LOCAL es aceptable usar valores simples.
# En PRODUCCIÓN:
# - Cambiar todas las contraseñas a valores complejos
# - Usar gestión de secretos (HashiCorp Vault, AWS Secrets Manager, etc.)
# - Nunca commitear .env a git
# - Usar variables de entorno del sistema operativo o contenedor
# ============================================================================
